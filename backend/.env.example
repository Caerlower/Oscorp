APP_NAME=Oscorp
API_PORT=8000
# Persist agent wallets + policy to disk (survives uvicorn --reload)
OSCORP_DATA_DIR=data

# Groq — drafts + Telegram conversation (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

X402_PAYER_URL=http://127.0.0.1:8110
# true = skip x402/provider HTTP (mock paid APIs); false = requires dev stack on :8110, :8101–8103
OSCORP_PROVIDER_STUB=false

ALGOD_ADDRESS=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
USDC_ASSET_ID=10458941
# Optional TestNet faucet (account with ALGO) — auto-funds agent wallets + USDC opt-in
OSCORP_DEV_FAUCET_MNEMONIC=
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080

TREND_ANALYZER_URL=http://127.0.0.1:8101
HOOK_GENERATOR_URL=http://127.0.0.1:8102
THREAD_GENERATOR_URL=http://127.0.0.1:8103

# Pre-cycle research via Groq (niche + memory; not live X API). false = stub topics only
OSCORP_GROQ_RESEARCH_ENABLED=true

# Telegram — Oscorp bot (@BotFather): chat, memory, /run, alerts
TELEGRAM_OPERATOR=oscorp
TELEGRAM_BOT_TOKEN=
