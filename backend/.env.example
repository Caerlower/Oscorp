API_PORT=8000
OSCORP_DATA_DIR=data

# Groq — company documents + site analysis (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Website analysis (optional)
FIRECRAWL_API_KEY=
PAGESPEED_API_KEY=

# Algorand TestNet node
ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
USDC_ASSET_ID=10458941

# x402 facilitator (used by app/core/x402_middleware.py)
FACILITATOR_URL=https://facilitator.goplausible.xyz

# Supabase — required for onboarding, agent deliverables, payment history.
# Use the service_role JWT from Dashboard → Settings → API (starts with eyJ…).
# Run backend/supabase/schema.sql in the SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional dev faucet — auto-sends TestNet ALGO to agent wallets during setup.
# Pydantic reads DEV_FAUCET_MNEMONIC or OSCORP_DEV_FAUCET_MNEMONIC.
DEV_FAUCET_MNEMONIC=

CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080
