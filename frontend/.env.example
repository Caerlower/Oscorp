# Oscorp frontend — copy to .env and fill in values.

# Backend API (Oscorp FastAPI). Local dev: uvicorn on port 8000.
VITE_API_URL=http://127.0.0.1:8000

# Algorand network for wallet + payments (testnet | mainnet).
VITE_ALGORAND_NETWORK=testnet

# USDC ASA on the selected network. TestNet default: 10458941.
VITE_USDC_ASSET_ID=10458941

# Algod node URL for on-chain reads. Public testnet node shown below.
VITE_ALGOD_URL=https://testnet-api.algonode.cloud

# Algod API token (empty for public nodes).
VITE_ALGOD_TOKEN=

# Web3Auth / MetaMask Embedded Wallets — create a project at https://developer.metamask.io/
VITE_WEB3AUTH_CLIENT_ID=
