# Copy to ~/.openclaw/.env

# Groq — chat model in Telegram (onboard: pick Groq, or set model groq/llama-3.3-70b-versatile)
GROQ_API_KEY=

# xAI — x_search for live X trends
XAI_API_KEY=

# Oscorp API (local backend)
OSCORP_API_URL=http://127.0.0.1:8000
OSCORP_USER_ID=

# Telegram token is configured in openclaw onboard (not here unless docs say TELEGRAM_BOT_TOKEN)
