OSCORP_API_URL=http://127.0.0.1:5050
OSCORP_API_KEY=oscorp_dev_key
OSCORP_ID=
GROQ_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
X_USERNAME=
X_PASSWORD=
X_EMAIL=
X_POSTING_MODE=browser
X_AUTO_LOGIN=false
X_EXECUTION_MODE=post
X_QUEUE_FEE_MICRO_USDC=10000
X_DEDUP_WINDOW_SECONDS=21600
BROWSER_HEADLESS=false
BROWSER_CHANNEL=chrome
# For Brave on macOS:
# BROWSER_EXECUTABLE_PATH=/Applications/Brave Browser.app/Contents/MacOS/Brave Browser
# To attach to an already running browser with remote debugging:
# BROWSER_CDP_URL=http://127.0.0.1:9222
# Optional custom profile dir for browser mode:
# BROWSER_PROFILE_DIR=/Users/you/.oscorp-agent/chrome-profile
AGENT_MODE=plan_only
AGENT_VERBOSE=true
AGENT_PRESENTATION_MODE=true
AGENT_CYCLE_INTERVAL=30
HEARTBEAT_INTERVAL=60
MAX_ITERATIONS=10
TX_EXPLORER_BASE_URL=http://127.0.0.1:8980/v2/transactions